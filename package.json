{
  "name": "eye",
  "version": "0.1.0",
  "description": "A TypeScript MCP server for source-code browsing in large repositories.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "bin": {
    "eye": "./dist/index.js"
  },
  "files": [
    "dist",
    ".eye",
    ".agents",
    "plans",
    "README.md",
    "AGENTS.md",
    "PLANS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev:docs": "pnpm docs:dev",
    "doctor": "tsx src/scripts/doctor.ts",
    "docs:build": "pnpm --filter eye-docs build",
    "docs:build:pages": "EYE_DOCS_BASE_PATH=/eye pnpm docs:build",
    "docs:check": "pnpm docs:build",
    "docs:dev": "pnpm --filter eye-docs dev --hostname 127.0.0.1 --port 3001",
    "hooks:install": "lefthook install",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "mcp:stdio": "tsx src/index.ts",
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:fixtures:real": "vitest run --config vitest.real-fixtures.config.ts",
    "test:coverage": "vitest run --config vitest.coverage.config.ts --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate": "pnpm run doctor && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:e2e && pnpm run test:coverage && pnpm run build",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "source-code",
    "navigation",
    "typescript",
    "ripgrep"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "better-sqlite3": "^12.8.0",
    "pyright": "^1.1.408",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "lefthook": "^2.1.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
