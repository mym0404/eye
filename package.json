{
  "name": "eye",
  "version": "0.1.0",
  "description": "A TypeScript MCP server for source-code browsing in large repositories.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "bin": {
    "eye": "./dist/index.js"
  },
  "files": [
    "dist",
    ".eye",
    "plans",
    "README.md",
    "AGENTS.md",
    "PLANS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "doctor": "tsx src/scripts/doctor.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate": "npm run doctor && npm run lint && npm run typecheck && npm run test:coverage",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "source-code",
    "navigation",
    "typescript",
    "ripgrep"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "better-sqlite3": "^12.8.0",
    "pyright": "^1.1.408",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@biomejs/biome": "^2.4.11",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
