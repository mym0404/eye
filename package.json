{
  "name": "eye",
  "version": "0.1.0",
  "description": "A TypeScript MCP server for source-code browsing in large repositories.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "eye": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "PLANS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "source-code",
    "navigation",
    "typescript",
    "ripgrep"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
